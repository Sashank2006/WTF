# WTF API — environment variables
# Copy this file to `.env` and fill in real values.

# Server port (Render sets this automatically; local default is 3000)
PORT=3000

# Gmail address that SENDS the email (your Gmail)
EMAIL_USER=youraddress@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# Generate at: Google Account → Security → 2-Step Verification (must be ON) → App passwords
EMAIL_PASS=your-16-char-app-password

# Email address that RECEIVES the contact-form messages
# Can be the same as EMAIL_USER, or a different one
TO_EMAIL=where-you-want-messages@gmail.com

# Comma-separated list of origins allowed to call this API
# For GitHub Pages: https://<user>.github.io
# For local dev:    http://localhost:5000
ALLOWED_ORIGIN=https://sashank2006.github.io,http://localhost:5000,http://127.0.0.1:5000